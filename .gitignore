# Build directory (out-of-source builds)
/build/
/build-*/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
CMakeUserPresets.json

# Compiled object files
*.o
*.obj
*.elf
*.bin
*.hex
*.uf2
*.map
*.lst
*.dis

# Compiled static/dynamic libraries
*.a
*.so
*.dylib

# Dependency files generated by the compiler
*.d
*.d.*

# Debug files
*.gdb
*.gdbinit

# IDE specific files (Visual Studio Code)
.vscode/
*.code-workspace

# IDE specific files (CLion)
.idea/

# macOS junk
.DS_Store

# Editor backup files
*~
*.swp
*.swo
*#

# Python cache (if using picotool scripts)
__pycache__/
*.py[cod]

